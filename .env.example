# ClawBox Configuration
# Copy this file to .env and fill in the values

# === Required ===

# Database (PostgreSQL with pgvector extension)
DATABASE_URL=postgresql://clawbox:clawbox@localhost:5432/clawbox
# When using `docker compose -f docker-compose.yml -f docker-compose.dev.yml`,
# this controls the host port that
# forwards to the Compose database container.
#POSTGRES_PORT=5432

# === Storage ===

# "local" = filesystem, "s3" = S3-compatible object storage
STORAGE_BACKEND=local

# Local storage path (when STORAGE_BACKEND=local)
LOCAL_STORAGE_PATH=./data

# S3-compatible storage (when STORAGE_BACKEND=s3)
# Works with: AWS S3, MinIO, GCS, Azure Blob, DigitalOcean Spaces
#S3_ENDPOINT_URL=            # Leave empty for AWS S3, set for MinIO/GCS/etc.
#AWS_ACCESS_KEY_ID=
#AWS_SECRET_ACCESS_KEY=
#S3_BUCKET_NAME=clawbox-files
#AWS_REGION=us-east-1

# Google OAuth (enables "Sign in with Google")
#GOOGLE_CLIENT_ID=xxx.apps.googleusercontent.com
#GOOGLE_CLIENT_SECRET=GOCSPX-xxx

# Session secret (change to a random string in production)
SESSION_SECRET_KEY=change-me-to-a-random-string
AUTO_MIGRATE_ON_STARTUP=false

# Google Gemini (enables semantic search & multimodal embeddings)
#GOOGLE_API_KEY=your-google-api-key-here
#EMBEDDING_MODEL=gemini-embedding-2-preview
#EMBEDDING_DIMENSIONS=768

# Public URL (used for OAuth callbacks and share links)
APP_URL=http://localhost:8000

# Server
HOST=0.0.0.0
PORT=8000
