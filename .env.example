# Database
DATABASE_URL=postgresql://agentbox:agentbox@localhost:5432/agentbox

# Storage (local or s3)
STORAGE_BACKEND=local
LOCAL_STORAGE_PATH=./data

# AWS / S3 (required if STORAGE_BACKEND=s3)
AWS_REGION=us-east-1
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
S3_BUCKET_NAME=

# Token settings
DEFAULT_STORAGE_LIMIT_BYTES=10485760

# Google Gemini (required for semantic search & multimodal embeddings)
GOOGLE_API_KEY=your-google-api-key-here
EMBEDDING_MODEL=gemini-embedding-2-preview
EMBEDDING_DIMENSIONS=768

# OpenAI (legacy, no longer used for embeddings)
# OPENAI_API_KEY=

# Server
HOST=0.0.0.0
PORT=8000
